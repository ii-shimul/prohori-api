# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=log

# PostgreSQL connection string used by Prisma. This is not the Supabase project URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase project URL, used for Auth/JWKS from Step 3 onward.
# SUPABASE_URL=https://your-project-ref.supabase.co

# Explicit browser origin allowed to call this API. Do not use '*'.
CORS_ORIGIN=http://localhost:3000
