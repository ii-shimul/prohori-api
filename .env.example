# Local API runtime
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=log

# Supabase/Postgres: DATABASE_URL is the local query connection; SUPABASE_URL is used only for Auth/JWKS.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=app
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_JWT_AUDIENCE=authenticated
# Set this to your local/hosted Supabase Auth issuer. Do not commit real tokens.
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1

# Server-to-server provider feed credentials. Use distinct non-production values locally;
# never expose these in web/mobile clients or commit production values.
INGESTION_PROVIDER_A_KEY=local-provider-a-key
INGESTION_PROVIDER_B_KEY=local-provider-b-key
INGESTION_PROVIDER_C_KEY=local-provider-c-key
