generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["app"]
}

enum ProviderCode {
  PROVIDER_A
  PROVIDER_B
  PROVIDER_C

  @@map("provider_code")
  @@schema("app")
}

enum UserRole {
  OUTLET_AGENT
  PROVIDER_OPERATIONS
  PLATFORM_MANAGEMENT
  DATA_STEWARD
  VALIDATION_AUDITOR
  DEMO_ADMIN

  @@map("user_role")
  @@schema("app")
}

enum ProviderStatus {
  ACTIVE
  INACTIVE

  @@map("provider_status")
  @@schema("app")
}

enum OutletStatus {
  ACTIVE
  INACTIVE

  @@map("outlet_status")
  @@schema("app")
}

model Provider {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        ProviderCode         @unique
  name        String               @unique
  status      ProviderStatus       @default(ACTIVE)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  memberships ProviderMembership[]
  assignments OutletAssignment[]
  providerBalances ProviderBalance[]
  transactions Transaction[]

  @@map("providers")
  @@schema("app")
}

model Area {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String             @unique
  name        String
  parentId    String?            @map("parent_id") @db.Uuid
  parent      Area?              @relation("AreaHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Area[]             @relation("AreaHierarchy")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  outlets     Outlet[]
  assignments OutletAssignment[]

  @@unique([parentId, name])
  @@map("areas")
  @@schema("app")
}

model Outlet {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  areaId      String             @map("area_id") @db.Uuid
  area        Area               @relation(fields: [areaId], references: [id], onDelete: Restrict)
  code        String             @unique
  name        String
  tier        Int
  timezone    String             @default("Asia/Dhaka")
  status      OutletStatus       @default(ACTIVE)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  assignments OutletAssignment[]
  cashBalance OutletCashBalance?
  providerBalances ProviderBalance[]
  transactions Transaction[]
  forecastRuns ForecastRun[]

  @@map("outlets")
  @@schema("app")
}

model Profile {
  id          String               @id @db.Uuid
  displayName String               @map("display_name")
  locale      String               @default("en")
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  memberships ProviderMembership[]
  assignments OutletAssignment[]

  @@map("profiles")
  @@schema("app")
}

model ProviderMembership {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  user       Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String       @map("provider_id") @db.Uuid
  provider   Provider     @relation(fields: [providerId], references: [id], onDelete: Restrict)
  role       UserRole
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, providerId, role])
  @@index([userId])
  @@index([providerId])
  @@map("provider_memberships")
  @@schema("app")
}

model OutletAssignment {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  user       Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  outletId   String        @map("outlet_id") @db.Uuid
  outlet     Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)
  areaId     String        @map("area_id") @db.Uuid
  area       Area          @relation(fields: [areaId], references: [id], onDelete: Restrict)
  providerId String?       @map("provider_id") @db.Uuid
  provider   Provider?     @relation(fields: [providerId], references: [id], onDelete: Restrict)
  role       UserRole
  isActive   Boolean       @default(true) @map("is_active")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([outletId])
  @@index([areaId])
  @@index([providerId])
  @@map("outlet_assignments")
  @@schema("app")
}

enum TransactionType {
  CASH_IN
  CASH_OUT

  @@map("transaction_type")
  @@schema("app")
}

enum TransactionLifecycle {
  PENDING
  SETTLED
  FAILED
  REVERSED

  @@map("transaction_lifecycle")
  @@schema("app")
}

model OutletCashBalance {
  outletId    String   @id @map("outlet_id") @db.Uuid
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  amountMinor BigInt   @map("amount_minor")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("outlet_cash_balances")
  @@schema("app")
}

model ProviderBalance {
  outletId    String   @map("outlet_id") @db.Uuid
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  providerId  String   @map("provider_id") @db.Uuid
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  amountMinor BigInt   @map("amount_minor")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([outletId, providerId])
  @@map("provider_balances")
  @@schema("app")
}

model ForecastRun {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId        String          @map("outlet_id") @db.Uuid
  outlet          Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  generatedAt     DateTime        @default(now()) @map("generated_at") @db.Timestamptz(6)
  dataQuality     String          @map("data_quality")
  modelConfidence Decimal         @map("model_confidence") @db.Decimal(5, 4)
  limitingResource String?        @map("limiting_resource")
  evidence        Json
  output          Json
  points          ForecastPoint[]

  @@index([outletId, generatedAt(sort: Desc)])
  @@map("forecast_runs")
  @@schema("app")
}

model ForecastPoint {
  id                         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  forecastRunId              String      @map("forecast_run_id") @db.Uuid
  forecastRun                ForecastRun @relation(fields: [forecastRunId], references: [id], onDelete: Cascade)
  providerId                 String?     @map("provider_id") @db.Uuid
  resource                   String
  horizonMinutes             Int         @map("horizon_minutes")
  projectedLowMinor          BigInt      @map("projected_low_minor")
  projectedHighMinor         BigInt      @map("projected_high_minor")
  projectedMidMinor          BigInt      @map("projected_mid_minor")
  riskBand                   String      @map("risk_band")
  reserveEtaMinutes          Int?        @map("reserve_eta_minutes")
  likelyDepletionEtaMinutes  Int?        @map("likely_depletion_eta_minutes")

  @@index([forecastRunId, resource, providerId])
  @@map("forecast_points")
  @@schema("app")
}

model FeedBatch {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId    String   @map("provider_id") @db.Uuid
  sequence      BigInt
  checksum      String
  receivedAt    DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  sourceAt      DateTime? @map("source_at") @db.Timestamptz(6)
  eventCount    Int      @default(0) @map("event_count")
  qualityStatus String   @default("healthy") @map("quality_status")

  @@unique([providerId, sequence])
  @@map("feed_batches")
  @@schema("app")
}

model BalanceSnapshot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId  String?  @map("provider_id") @db.Uuid
  outletId    String   @map("outlet_id") @db.Uuid
  resource    String
  amountMinor BigInt   @map("amount_minor")
  observedAt  DateTime @map("observed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("balance_snapshots")
  @@schema("app")
}

model SimulationBalanceBaseline {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId    String   @map("outlet_id") @db.Uuid
  providerId  String?  @map("provider_id") @db.Uuid
  resource    String
  amountMinor BigInt   @map("amount_minor")

  @@unique([outletId, providerId, resource])
  @@map("simulation_balance_baselines")
  @@schema("app")
}

model SimulationState {
  id       String @id
  scenario String
  step     Int

  @@map("simulation_state")
  @@schema("app")
}

model DataQualityIncident {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String?   @map("provider_id") @db.Uuid
  outletId   String?   @map("outlet_id") @db.Uuid
  category   String
  details    Json      @default("{}")
  detectedAt DateTime  @default(now()) @map("detected_at") @db.Timestamptz(6)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz(6)

  @@map("data_quality_incidents")
  @@schema("app")
}

model Transaction {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId      String               @map("provider_id") @db.Uuid
  provider        Provider             @relation(fields: [providerId], references: [id], onDelete: Restrict)
  outletId        String               @map("outlet_id") @db.Uuid
  outlet          Outlet               @relation(fields: [outletId], references: [id], onDelete: Restrict)
  feedBatchId     String?              @map("feed_batch_id") @db.Uuid
  providerEventId String               @map("provider_event_id")
  eventVersion    Int                  @default(1) @map("event_version")
  type            TransactionType
  lifecycle       TransactionLifecycle
  amountMinor     BigInt               @map("amount_minor")
  occurredAt      DateTime             @map("occurred_at") @db.Timestamptz(6)
  idempotencyKey  String               @map("idempotency_key")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([providerId, providerEventId])
  @@unique([providerId, idempotencyKey])
  @@map("transactions")
  @@schema("app")
}
