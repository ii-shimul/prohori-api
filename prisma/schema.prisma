generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["app"]
}

enum ProviderCode {
  PROVIDER_A
  PROVIDER_B
  PROVIDER_C

  @@map("provider_code")
  @@schema("app")
}

enum UserRole {
  OUTLET_AGENT
  PROVIDER_OPERATIONS
  PLATFORM_MANAGEMENT
  DATA_STEWARD
  VALIDATION_AUDITOR
  DEMO_ADMIN

  @@map("user_role")
  @@schema("app")
}

enum ProviderStatus {
  ACTIVE
  INACTIVE

  @@map("provider_status")
  @@schema("app")
}

enum OutletStatus {
  ACTIVE
  INACTIVE

  @@map("outlet_status")
  @@schema("app")
}

model Provider {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        ProviderCode         @unique
  name        String               @unique
  status      ProviderStatus       @default(ACTIVE)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  memberships ProviderMembership[]
  assignments OutletAssignment[]
  providerBalances ProviderBalance[]
  transactions Transaction[]
  anomalySignals AnomalySignal[]

  @@map("providers")
  @@schema("app")
}

model Area {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String             @unique
  name        String
  parentId    String?            @map("parent_id") @db.Uuid
  parent      Area?              @relation("AreaHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Area[]             @relation("AreaHierarchy")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  outlets     Outlet[]
  assignments OutletAssignment[]

  @@unique([parentId, name])
  @@map("areas")
  @@schema("app")
}

model Outlet {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  areaId      String             @map("area_id") @db.Uuid
  area        Area               @relation(fields: [areaId], references: [id], onDelete: Restrict)
  code        String             @unique
  name        String
  tier        Int
  timezone    String             @default("Asia/Dhaka")
  status      OutletStatus       @default(ACTIVE)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  assignments OutletAssignment[]
  cashBalance OutletCashBalance?
  providerBalances ProviderBalance[]
  transactions Transaction[]
  forecastRuns ForecastRun[]
  anomalySignals AnomalySignal[]

  @@map("outlets")
  @@schema("app")
}

model Profile {
  id          String               @id @db.Uuid
  displayName String               @map("display_name")
  locale      String               @default("en")
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  memberships ProviderMembership[]
  assignments OutletAssignment[]

  @@map("profiles")
  @@schema("app")
}

model ProviderMembership {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  user       Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String       @map("provider_id") @db.Uuid
  provider   Provider     @relation(fields: [providerId], references: [id], onDelete: Restrict)
  role       UserRole
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, providerId, role])
  @@index([userId])
  @@index([providerId])
  @@map("provider_memberships")
  @@schema("app")
}

model OutletAssignment {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  user       Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  outletId   String        @map("outlet_id") @db.Uuid
  outlet     Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)
  areaId     String        @map("area_id") @db.Uuid
  area       Area          @relation(fields: [areaId], references: [id], onDelete: Restrict)
  providerId String?       @map("provider_id") @db.Uuid
  provider   Provider?     @relation(fields: [providerId], references: [id], onDelete: Restrict)
  role       UserRole
  isActive   Boolean       @default(true) @map("is_active")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([outletId])
  @@index([areaId])
  @@index([providerId])
  @@map("outlet_assignments")
  @@schema("app")
}

enum TransactionType {
  CASH_IN
  CASH_OUT

  @@map("transaction_type")
  @@schema("app")
}

enum TransactionLifecycle {
  PENDING
  SETTLED
  FAILED
  REVERSED

  @@map("transaction_lifecycle")
  @@schema("app")
}

model OutletCashBalance {
  outletId    String   @id @map("outlet_id") @db.Uuid
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  amountMinor BigInt   @map("amount_minor")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("outlet_cash_balances")
  @@schema("app")
}

model ProviderBalance {
  outletId    String   @map("outlet_id") @db.Uuid
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  providerId  String   @map("provider_id") @db.Uuid
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  amountMinor BigInt   @map("amount_minor")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([outletId, providerId])
  @@map("provider_balances")
  @@schema("app")
}

model ForecastRun {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId        String          @map("outlet_id") @db.Uuid
  outlet          Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  generatedAt     DateTime        @default(now()) @map("generated_at") @db.Timestamptz(6)
  dataQuality     String          @map("data_quality")
  modelConfidence Decimal         @map("model_confidence") @db.Decimal(5, 4)
  limitingResource String?        @map("limiting_resource")
  evidence        Json
  output          Json
  points          ForecastPoint[]
  anomalyCorrelations LiquidityAnomalyCorrelation[]

  @@index([outletId, generatedAt(sort: Desc)])
  @@map("forecast_runs")
  @@schema("app")
}

model ForecastPoint {
  id                         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  forecastRunId              String      @map("forecast_run_id") @db.Uuid
  forecastRun                ForecastRun @relation(fields: [forecastRunId], references: [id], onDelete: Cascade)
  providerId                 String?     @map("provider_id") @db.Uuid
  resource                   String
  horizonMinutes             Int         @map("horizon_minutes")
  projectedLowMinor          BigInt      @map("projected_low_minor")
  projectedHighMinor         BigInt      @map("projected_high_minor")
  projectedMidMinor          BigInt      @map("projected_mid_minor")
  riskBand                   String      @map("risk_band")
  reserveEtaMinutes          Int?        @map("reserve_eta_minutes")
  likelyDepletionEtaMinutes  Int?        @map("likely_depletion_eta_minutes")

  @@index([forecastRunId, resource, providerId])
  @@map("forecast_points")
  @@schema("app")
}

model AnomalySignal {
  id                        String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId                  String                       @map("outlet_id") @db.Uuid
  outlet                    Outlet                       @relation(fields: [outletId], references: [id], onDelete: Cascade)
  providerId                String                       @map("provider_id") @db.Uuid
  provider                  Provider                     @relation(fields: [providerId], references: [id], onDelete: Restrict)
  detectorType              String                       @map("detector_type")
  detectorVersion           String                       @map("detector_version")
  threshold                 Decimal
  observedValue             Decimal                      @map("observed_value")
  baselineValue             Decimal                      @map("baseline_value")
  score                     Decimal                      @db.Decimal(5, 4)
  sourceTransactionIds      Json                         @map("source_transaction_ids")
  evidenceWindowStart       DateTime                     @map("evidence_window_start") @db.Timestamptz(6)
  evidenceWindowEnd         DateTime                     @map("evidence_window_end") @db.Timestamptz(6)
  possibleBenignExplanation String                       @map("possible_benign_explanation")
  modelConfidence           Decimal                      @map("model_confidence") @db.Decimal(5, 4)
  dataQuality               String                       @map("data_quality")
  createdAt                 DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  correlation               LiquidityAnomalyCorrelation?

  @@unique([outletId, providerId, detectorType, detectorVersion, evidenceWindowEnd])
  @@index([outletId, providerId, evidenceWindowEnd(sort: Desc)])
  @@map("anomaly_signals")
  @@schema("app")
}

model LiquidityAnomalyCorrelation {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  anomalySignalId      String        @unique @map("anomaly_signal_id") @db.Uuid
  anomalySignal        AnomalySignal @relation(fields: [anomalySignalId], references: [id], onDelete: Cascade)
  forecastRunId        String        @map("forecast_run_id") @db.Uuid
  forecastRun          ForecastRun   @relation(fields: [forecastRunId], references: [id], onDelete: Cascade)
  correlationThreshold Decimal       @map("correlation_threshold") @db.Decimal(5, 4)
  correlationScore     Decimal       @map("correlation_score") @db.Decimal(5, 4)
  context              String
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([forecastRunId])
  @@map("liquidity_anomaly_correlations")
  @@schema("app")
}

model FeedBatch {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId    String   @map("provider_id") @db.Uuid
  sequence      BigInt
  checksum      String
  receivedAt    DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  sourceAt      DateTime? @map("source_at") @db.Timestamptz(6)
  eventCount    Int      @default(0) @map("event_count")
  qualityStatus String   @default("healthy") @map("quality_status")

  @@unique([providerId, sequence])
  @@map("feed_batches")
  @@schema("app")
}

model BalanceSnapshot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId  String?  @map("provider_id") @db.Uuid
  outletId    String   @map("outlet_id") @db.Uuid
  resource    String
  amountMinor BigInt   @map("amount_minor")
  observedAt  DateTime @map("observed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("balance_snapshots")
  @@schema("app")
}

model SimulationBalanceBaseline {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId    String   @map("outlet_id") @db.Uuid
  providerId  String?  @map("provider_id") @db.Uuid
  resource    String
  amountMinor BigInt   @map("amount_minor")

  @@unique([outletId, providerId, resource])
  @@map("simulation_balance_baselines")
  @@schema("app")
}

model SimulationState {
  id       String @id
  scenario String
  step     Int

  @@map("simulation_state")
  @@schema("app")
}

model DataQualityIncident {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String?   @map("provider_id") @db.Uuid
  outletId   String?   @map("outlet_id") @db.Uuid
  category   String
  details    Json      @default("{}")
  detectedAt DateTime  @default(now()) @map("detected_at") @db.Timestamptz(6)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz(6)

  @@map("data_quality_incidents")
  @@schema("app")
}



model Alert {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId String @map("outlet_id") @db.Uuid
  providerId String? @map("provider_id") @db.Uuid
  resource String?
  type String
  severity String
  status String @default("open")
  fingerprint String @unique
  episodeStartedAt DateTime @map("episode_started_at") @db.Timestamptz(6)
  lastObservedAt DateTime @map("last_observed_at") @db.Timestamptz(6)
  occurrenceCount Int @default(1) @map("occurrence_count")
  messageKey String @map("message_key")
  messageParams Json @default("{}") @map("message_params")
  evidence Json @default("{}")
  dataQuality String @map("data_quality")
  modelConfidence Decimal @map("model_confidence") @db.Decimal(5, 4)
  ownerUserId String? @map("owner_user_id") @db.Uuid
  acknowledgedAt DateTime? @map("acknowledged_at") @db.Timestamptz(6)
  acknowledgedBy String? @map("acknowledged_by") @db.Uuid
  active Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([outletId, providerId, active, lastObservedAt(sort: Desc)])
  @@map("alerts")
  @@schema("app")
}

model AlertEvidenceSnapshot {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId String @map("alert_id") @db.Uuid
  observedAt DateTime @map("observed_at") @db.Timestamptz(6)
  kind String
  snapshot Json

  @@index([alertId, observedAt(sort: Desc)])
  @@map("alert_evidence_snapshots")
  @@schema("app")
}

model AlertRoute {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId String @map("alert_id") @db.Uuid
  recipientUserId String @map("recipient_user_id") @db.Uuid
  routeKind String @map("route_kind")
  redacted Boolean @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([alertId, recipientUserId])
  @@index([recipientUserId, alertId])
  @@map("alert_routes")
  @@schema("app")
}

model AlertCaseRequest {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId String @unique @map("alert_id") @db.Uuid
  requestedBy String @map("requested_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("alert_case_requests")
  @@schema("app")
}

model AlertActionIdempotency {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId String @map("alert_id") @db.Uuid
  actorUserId String @map("actor_user_id") @db.Uuid
  action String
  idempotencyKey String @map("idempotency_key")
  response Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([actorUserId, action, idempotencyKey])
  @@map("alert_action_idempotency")
  @@schema("app")
}

model Case {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId          String   @map("outlet_id") @db.Uuid
  providerId        String?  @map("provider_id") @db.Uuid
  state             String   @default("OPEN")
  version           Int      @default(1)
  ownerUserId       String?  @map("owner_user_id") @db.Uuid
  resolutionCode    String?  @map("resolution_code")
  resolutionSummary String?  @map("resolution_summary")
  createdBy         String   @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  resolvedAt        DateTime? @map("resolved_at") @db.Timestamptz(6)
  closedAt          DateTime? @map("closed_at") @db.Timestamptz(6)

  @@index([outletId, providerId, state, updatedAt(sort: Desc)])
  @@map("cases")
  @@schema("app")
}

model CaseAlertLink {
  caseId   String   @map("case_id") @db.Uuid
  alertId  String   @unique @map("alert_id") @db.Uuid
  linkedAt DateTime @default(now()) @map("linked_at") @db.Timestamptz(6)
  linkedBy String   @map("linked_by") @db.Uuid

  @@id([caseId, alertId])
  @@map("case_alert_links")
  @@schema("app")
}

model CaseEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId        String   @map("case_id") @db.Uuid
  eventType     String   @map("event_type")
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  oldState      String?  @map("old_state")
  newState      String?  @map("new_state")
  metadata      Json     @default("{}")
  correlationId String   @map("correlation_id") @db.Uuid
  wallAt        DateTime @map("wall_at") @db.Timestamptz(6)
  simulatedAt   DateTime? @map("simulated_at") @db.Timestamptz(6)

  @@index([caseId, wallAt])
  @@map("case_events")
  @@schema("app")
}

model CaseNote {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId       String   @map("case_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([caseId, createdAt])
  @@map("case_notes")
  @@schema("app")
}

model AuditEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  actorType    String   @map("actor_type")
  action       String
  targetType   String   @map("target_type")
  targetId     String   @map("target_id") @db.Uuid
  providerId   String?  @map("provider_id") @db.Uuid
  outletId     String?  @map("outlet_id") @db.Uuid
  oldState     String?  @map("old_state")
  newState     String?  @map("new_state")
  safeMetadata Json     @default("{}") @map("safe_metadata")
  wallAt       DateTime @map("wall_at") @db.Timestamptz(6)
  simulatedAt  DateTime? @map("simulated_at") @db.Timestamptz(6)
  correlationId String  @map("correlation_id") @db.Uuid

  @@index([targetType, targetId, wallAt])
  @@map("audit_events")
  @@schema("app")
}

model CaseCommandIdempotency {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId    String   @map("actor_user_id") @db.Uuid
  action         String
  idempotencyKey String   @map("idempotency_key")
  caseId         String   @map("case_id") @db.Uuid
  response       Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([actorUserId, action, idempotencyKey])
  @@map("case_command_idempotency")
  @@schema("app")
}

model Transaction {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId      String               @map("provider_id") @db.Uuid
  provider        Provider             @relation(fields: [providerId], references: [id], onDelete: Restrict)
  outletId        String               @map("outlet_id") @db.Uuid
  outlet          Outlet               @relation(fields: [outletId], references: [id], onDelete: Restrict)
  feedBatchId     String?              @map("feed_batch_id") @db.Uuid
  providerEventId String               @map("provider_event_id")
  eventVersion    Int                  @default(1) @map("event_version")
  type            TransactionType
  lifecycle       TransactionLifecycle
  amountMinor     BigInt               @map("amount_minor")
  occurredAt      DateTime             @map("occurred_at") @db.Timestamptz(6)
  idempotencyKey  String               @map("idempotency_key")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([providerId, providerEventId])
  @@unique([providerId, idempotencyKey])
  @@map("transactions")
  @@schema("app")
}
